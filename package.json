{
	"name": "prism-wiki",
	"version": "2.1.1",
	"description": "A Prism gadget for MediaWiki sites",
	"keywords": [
		"prism",
		"highlight",
		"mediawiki",
		"wikitext"
	],
	"homepage": "https://github.com/bhsd-harry/prism-wiki#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/prism-wiki/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"/dist/*.js",
		"/dist/wiki.d.ts"
	],
	"main": "./dist/wiki.js",
	"browser": "/dist/main.min.js",
	"types": "./dist/wiki.d.ts",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/prism-wiki.git"
	},
	"scripts": {
		"ls": "npm i --package-lock-only && npm ls --package-lock-only --all --omit=dev",
		"prepublishOnly": "npm run build",
		"lint:ts": "tsc --noEmit && tsc --noEmit --project test/tsconfig.json && eslint --cache .",
		"lint:css": "stylelint *.css",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:css && npm run lint:md",
		"bundle": "node bundle.cjs",
		"build:test": "rm -rf test/dist/; tsc --project test/tsconfig.json && npm test",
		"build:gh-page": "esbuild src/gh-page.ts --charset=utf8 --bundle --target=es2019 --format=esm --minify --sourcemap --outfile=dist/gh-page.mjs",
		"build": "tsc && rm dist/[ghm]*.[jt]s && npm run bundle && eslint --no-config-lookup -c eslint.dist.mjs dist/main.min.js && npm run build:gh-page",
		"server": "npm run test:end; http-server .. -c-1 --cors -s &",
		"prof": "node test/dist/prof.js",
		"test": "mocha",
		"test:real": "node test/dist/real.js",
		"test:end": "pkill -x http-server"
	},
	"dependencies": {
		"@types/prismjs": "^1.26.6"
	},
	"devDependencies": {
		"@bhsd/browser": "^0.4.0",
		"@bhsd/code-standard": "^2.5.0",
		"@bhsd/codemirror-mediawiki": "^3.18.1",
		"@bhsd/common": "^2.2.1",
		"@bhsd/nodejs": "^1.0.0",
		"@bhsd/test-util": "^1.3.1",
		"@stylistic/stylelint-plugin": "^5.1.0",
		"@types/jquery": "^3.5.34",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.9.0",
		"@typescript-eslint/parser": "^8.59.4",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"markdownlint-cli2": "^0.22.1",
		"mocha": "^11.7.5",
		"stylelint": "^17.12.0",
		"stylelint-config-recommended": "^18.0.0",
		"stylelint-plugin-use-baseline": "^1.4.2",
		"types-mediawiki": "^2.0.0",
		"typescript": "^6.0.3",
		"wikilint": "^2.40.0",
		"wikiparser-node": "^1.40.0"
	},
	"engines": {
		"node": "^20.19.0 || ^22.13.0 || >=24.11.0"
	}
}
